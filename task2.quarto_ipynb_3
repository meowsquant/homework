    "# ========== 用 pandas 计算整列日收益率 ==========\n",
    "df = df_aapl[['Close']].copy()              # 只保留收盘价一列\n",
    "df['daily_return'] = df['Close'].pct_change()  # 今天相对昨天的涨跌比例\n",
    "\n",
    "print('closing price and daily return in the past 10 days：')  # 打印输出\n",
    "display(df.tail(10))  # 在 Notebook 中美观显示表格\n",
    "\n",
