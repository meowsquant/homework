    "# ========== 特斯拉双均线策略（完整示例） ==========\n",
    "import akshare as ak\n",
    "from datetime import datetime, timedelta\n",
    "\n",
    "# 获取美股数据\n",
    "df_tsla = ak.stock_us_daily(symbol='TSLA', adjust='qfq')\n",
    "df_tsla['date'] = pd.to_datetime(df_tsla['date'])\n",
    "df_tsla = df_tsla.set_index('date').sort_index()\n",
    "# 截取近 500 个交易日\n",
    "df_tsla = df_tsla.tail(500).copy()\n",
    "df_tsla.columns = [col.capitalize() for col in df_tsla.columns]\n",
    "\n",
    "# 计算均线\n",
    "df_tsla['MA5'] = df_tsla['Close'].rolling(5).mean()\n",
    "df_tsla['MA20'] = df_tsla['Close'].rolling(20).mean()\n",
    "\n",
    "# 金叉死叉\n",
    "df_tsla['spread'] = df_tsla['MA5'] - df_tsla['MA20']\n",
    "df_tsla['cross'] = np.sign(df_tsla['spread']).diff()\n",
    "df_tsla['signal'] = (df_tsla['MA5'] > df_tsla['MA20']).astype(int)\n",
    "df_tsla['trade'] = 0\n",
    "df_tsla.loc[df_tsla['cross'] > 0, 'trade'] = 1\n",
    "df_tsla.loc[df_tsla['cross'] < 0, 'trade'] = -1\n",
    "\n",
    "golden = df_tsla[df_tsla['cross'] > 0].dropna(subset=['MA5', 'MA20'])\n",
    "death = df_tsla[df_tsla['cross'] < 0].dropna(subset=['MA5', 'MA20'])\n",
    "\n",
    "print(f'TSLA 样本期内 金叉 {len(golden)} 次，死叉 {len(death)} 次')\n",
    "print(f'持仓天数：{df_tsla[\"signal\"].sum()} / {len(df_tsla)}')\n",
