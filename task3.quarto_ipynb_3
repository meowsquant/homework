    "# ========== 检测金叉、死叉 ==========\n",
    "df['spread'] = df['MA5'] - df['MA20']              # 短均线减长均线\n",
    "df['cross'] = np.sign(df['spread']).diff()         # 符号变化：正=金叉，负=死叉\n",
