    "# ========== 获取特斯拉数据（MA10 vs MA30） ==========\n",
    "# 参数设置\n",
    "SYMBOL = \"TSLA\"\n",
    "STOCK_NAME = \"Tesla\"\n",
    "DAYS = 500\n",
    "SHORT_WIN = 10\n",
    "LONG_WIN = 30\n",
    "\n",
    "# 获取数据\n",
    "df_raw = ak.stock_us_daily(symbol=SYMBOL, adjust=\"qfq\")\n",
    "df_raw[\"date\"] = pd.to_datetime(df_raw[\"date\"])\n",
    "df = df_raw.set_index(\"date\").sort_index()\n",
    "df.columns = [\n",
    "    col.capitalize() for col in df.columns\n",
    "]  # 首字母大写：Open, High, Low, Close, Volume\n",
    "df = df.tail(DAYS).copy()\n",
    "\n",
    "# 计算均线\n",
    "short_ma = f\"MA{SHORT_WIN}\"\n",
    "long_ma = f\"MA{LONG_WIN}\"\n",
    "df[short_ma] = df[\"Close\"].rolling(SHORT_WIN).mean()\n",
    "df[long_ma] = df[\"Close\"].rolling(LONG_WIN).mean()\n",
    "\n",
    "# 金叉死叉检测\n",
    "df[\"spread\"] = df[short_ma] - df[long_ma]\n",
    "df[\"cross\"] = np.sign(df[\"spread\"]).diff()\n",
    "df[\"signal\"] = (df[short_ma] > df[long_ma]).astype(int)\n",
    "df[\"trade\"] = 0\n",
    "df.loc[df[\"cross\"] > 0, \"trade\"] = 1\n",
    "df.loc[df[\"cross\"] < 0, \"trade\"] = -1\n",
    "\n",
    "golden = df[df[\"cross\"] > 0].dropna(subset=[short_ma, long_ma])\n",
    "death = df[df[\"cross\"] < 0].dropna(subset=[short_ma, long_ma])\n",
    "\n",
    "print(f\"{STOCK_NAME} ({SYMBOL}) 样本内共 {len(df)} 个交易日\")\n",
    "print(f\"均线组合: {short_ma} vs {long_ma}\")\n",
    "print(f\"金叉 {len(golden)} 次，死叉 {len(death)} 次\")\n",
    "print(f\"持仓天数：{df['signal'].sum()} / {len(df)}\")\n",
    "display(df.tail(8))"
   ]
  },
