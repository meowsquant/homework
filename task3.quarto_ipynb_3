    "# ========== 获取特斯拉数据 ==========\n",
    "# ========== 获取特斯拉数据（直接使用 akshare） ==========\n",
    "SYMBOL = \"TSLA\"\n",
    "STOCK_NAME = \"Tesla\"\n",
    "DAYS = 500\n",
    "\n",
    "# 直接下载美股日线数据\n",
    "df_raw = ak.stock_us_daily(symbol=SYMBOL, adjust=\"qfq\")\n",
    "df_raw[\"date\"] = pd.to_datetime(df_raw[\"date\"])\n",
    "df = df_raw.set_index(\"date\").sort_index()\n",
    "df.columns = [col.capitalize() for col in df.columns]  # 统一列名首字母大写\n",
    "df = df.tail(DAYS).copy()\n",
    "\n",
    "# 计算 MA5 和 MA20\n",
    "df[\"MA5\"] = df[\"Close\"].rolling(5).mean()\n",
    "df[\"MA20\"] = df[\"Close\"].rolling(20).mean()\n",
    "\n",
    "# 金叉死叉检测（与之前完全相同）\n",
    "df[\"spread\"] = df[\"MA5\"] - df[\"MA20\"]\n",
    "df[\"cross\"] = np.sign(df[\"spread\"]).diff()\n",
    "df[\"signal\"] = (df[\"MA5\"] > df[\"MA20\"]).astype(int)\n",
    "df[\"trade\"] = 0\n",
    "df.loc[df[\"cross\"] > 0, \"trade\"] = 1\n",
    "df.loc[df[\"cross\"] < 0, \"trade\"] = -1\n",
    "\n",
    "golden = df[df[\"cross\"] > 0].dropna(subset=[\"MA5\", \"MA20\"])\n",
    "death = df[df[\"cross\"] < 0].dropna(subset=[\"MA5\", \"MA20\"])\n",
    "\n",
    "print(f\"{STOCK_NAME} ({SYMBOL}) 样本内共 {len(df)} 个交易日\")\n",
    "print(f\"金叉 {len(golden)} 次，死叉 {len(death)} 次\")\n",
    "print(f\"持仓天数：{df['signal'].sum()} / {len(df)}\")\n",
    "display(df.tail(8))\n",
    "print(f\"金叉 {len(golden)} 次，死叉 {len(death)} 次\")\n",
    "print(f\"持仓天数：{df['signal'].sum()} / {len(df)}\")\n",
    "display(df.tail(8))"
   ]
  },
