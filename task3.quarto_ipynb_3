    "# ========== 模拟三种市场状态并分区上色 ==========\n",
    "np.random.seed(7)              # 固定随机数，图可复现\n",
    "n_up, n_down, n_noise = 60, 50, 70  # 上涨段、下跌段、横盘段各多少天\n",
    "\n",
    "ret_up = np.random.normal(0.004, 0.008, n_up)        # 上涨段：平均日收益偏正\n",
    "ret_down = np.random.normal(-0.005, 0.010, n_down)   # 下跌段：平均日收益偏负\n",
    "ret_noise = np.random.normal(0.0, 0.015, n_noise)    # 横盘：均值约0，波动大\n",
    "\n",
    "price = 100 * np.cumprod(1 + np.r_[ret_up, ret_down, ret_noise])  # 拼成价格\n",
    "x = np.arange(len(price))  # 横轴：第几个交易日\n",
    "\n",
    "fig, ax = plt.subplots(figsize=(13, 5))  # 创建子图\n",
    "ax.plot(x, price, color='black', linewidth=1.2, label='Price')  # 在子图上画折线\n",
    "\n",
    "ax.axvspan(0, n_up, alpha=0.15, color='green', label='Uptrend')  # 用色块标出区间\n",
    "ax.axvspan(n_up, n_up + n_down, alpha=0.15, color='red', label='Downtrend')  # 用色块标出区间\n",
    "ax.axvspan(n_up + n_down, len(price), alpha=0.15, color='gray', label='Noise / Sideways')  # 用色块标出区间\n",
    "\n",
    "ax.set_title('Three Market States (Simulation): Trend vs Noise', fontsize=14)  # 设置子图标题\n",
    "ax.set_xlabel('Trading Day (Illustrative)')  # 设置子图横轴\n",
    "ax.set_ylabel('Price')  # 设置子图纵轴\n",
    "ax.legend(loc='upper left')  # 显示图例\n",
    "ax.grid(True, alpha=0.3)  # 显示网格\n",
    "plt.tight_layout()                       # 自动调整子图间距，避免标签被裁切\n",
    "plt.show()                               # 在 Notebook 里显示图片\n",
    "\n",
    "print('Green zone: overall upward | Red zone: overall downward | Gray zone: directionless, high fluctuation')  # 解读三色区域含义"
